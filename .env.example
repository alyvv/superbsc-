# MEFAI Terminal Configuration

# Binance API Key (optional — only needed for Spot Trading panel)
# Get yours at: https://www.binance.com/en/my/settings/api-management
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Proxy settings
PROXY_HOST=0.0.0.0
PROXY_PORT=8000
CACHE_TTL=5

# Auto-Scanner interval (seconds)
SCANNER_INTERVAL=30
